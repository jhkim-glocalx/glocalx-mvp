{
  "name": "glocalx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev -w apps/owner-app --",
    "build": "npm run build -w apps/owner-app",
    "db:pg:migrate": "npm run db:pg:migrate -w apps/owner-app",
    "db:pg:reset": "npm run db:pg:reset -w apps/owner-app",
    "db:pg:seed": "npm run db:pg:seed -w apps/owner-app",
    "db:pg:verify": "npm run db:pg:verify -w apps/owner-app",
    "db:migrate:sqlite-to-pg": "npm run db:migrate:sqlite-to-pg -w apps/owner-app",
    "db:reset": "npm run db:reset -w apps/owner-app",
    "db:seed": "npm run db:seed -w apps/owner-app",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "e2e": "npm run e2e -w apps/owner-app",
    "e2e:postgres": "npm run e2e:postgres -w apps/owner-app",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "typescript": "latest"
  }
}
