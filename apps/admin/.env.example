# Admin dashboard environment template. Copy to .env.local for local dev.
# SQLite is the local default; any Vercel runtime requires Postgres.

# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgres://...        # pooled Neon URL (runtime)
# DATABASE_URL_DIRECT=postgres://... # direct Neon URL (migrations/ops)

# Admin seeding (never commit real values; pass in the shell):
# ADMIN_SEED_EMAIL=ops@example.com
# ADMIN_SEED_PASSWORD=change-me-please
# ADMIN_SEED_NAME=Operator
# ADMIN_SEED_ROLE=OWNER
