NEXT_PUBLIC_APP_NAME=GlocalX
APP_INTEGRATION_MODE=stub
ENABLE_ADMIN_DEBUG=false
RUN_LIVE_INTEGRATION_TESTS=0
DATABASE_PROVIDER=sqlite
GLOCALX_DB_PATH=.glocalx/dev.db
# Production-like Vercel deployments must set DATABASE_PROVIDER=postgres and both URL roles.
# DATABASE_URL=[pooled-postgres-url]
# DATABASE_URL_DIRECT=[direct-postgres-url]
# Vercel-managed Neon may provide the direct role as DATABASE_URL_UNPOOLED instead.
# DATABASE_URL_UNPOOLED=[direct-postgres-url]
DATABASE_POOL_MAX=5
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_ONBOARDING_SLOT_MODEL=gpt-5.4-mini
OPENAI_MARKETING_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1.5
NAVER_CLIENT_ID=replace-with-naver-client-id
NAVER_CLIENT_SECRET=replace-with-naver-client-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=
GOOGLE_BUSINESS_ACCOUNT_ID=replace-with-google-business-account-id
TEST_GBP_LOCATION_ID=replace-with-test-gbp-location-id
INSTAGRAM_ACCESS_TOKEN=replace-with-instagram-access-token
INSTAGRAM_USER_ID=replace-with-instagram-business-account-id
# Public HTTPS origin used by GBP and Instagram to fetch draft media.
PUBLIC_APP_URL=https://replace-with-production-app.example
# Optional separate signing key; TOKEN_ENCRYPTION_KEY is used when omitted.
POST_MEDIA_SIGNING_KEY=replace-with-high-entropy-signing-key
KAKAO_REST_API_KEY=replace-with-kakao-rest-api-key
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token
# The blob object host from the store's dashboard (e.g. ce0rcu23vrrdzqap.private.blob.vercel-storage.com) — Vercel Blob never returns this before an upload completes, so it can't be derived at runtime.
BLOB_PUBLIC_HOST=replace-with-vercel-blob-store-host
# Required wherever OAuth tokens are stored. Generate a real 32-byte base64 key with:
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
MIGRATION_EXPORT_ENCRYPTION_KEY=replace-with-32-byte-base64-key
